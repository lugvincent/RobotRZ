     </table:table-cell>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>_</text:p>
     </table:table-cell>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>Cste</text:p>
     </table:table-cell>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>ACK</text:p>
     </table:table-cell>
     <table:table-cell office:value-type="string" calcext:value-type="string">
