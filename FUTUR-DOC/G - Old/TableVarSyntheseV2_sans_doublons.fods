     </table:table-cell>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>mm;mm;ticks;×1000;×1000;ms;ms;ms</text:p>
     </table:table-cell>
     <table:table-cell office:value-type="string" calcext:value-type="string">
