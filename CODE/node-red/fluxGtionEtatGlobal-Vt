    {
        "id": "fn_build_event",
        "type": "function",
        "z": "sf_dispatcher_etatglobal_v1",
        "name": "Construire msg.event (normalisation)",
        "func": "// ============================================\n// SF_Dispatcher_EtatGlobal – V1\n// Construction du message canonique msg.event\n// ============================================\n\n// Valeurs par défaut sécurisées\nlet source = \"UNKNOWN\";\nlet intent = \"UNKNOWN\";\nlet priority = \"NORMAL\";\nlet payload = {};\n\n// --- Détection de la source ---\nif (msg.source) {\n    source = msg.source;\n} else if (msg.topic === \"VPIV\") {\n    source = \"VPIV\";\n} else if (msg.ui_event) {\n    source = \"UI\";\n} else if (msg.system_event) {\n    source = \"SYSTEM\";\n} else if (msg.init_event) {\n    source = \"INIT\";\n}\n\n// --- Détection de l'intention ---\nif (msg.intent) {\n    intent = msg.intent;\n} else if (msg.payload && msg.payload.modeRZ !== undefined) {\n    intent = \"SET_MODE\";\n} else if (msg.payload && msg.payload.typePtge !== undefined) {\n    intent = \"SET_PILOTAGE\";\n} else if (msg.payload === true && msg.topic === \"RESET\") {\n    intent = \"RESET\";\n} else if (msg.payload === true && msg.topic === \"CLEAR\") {\n    intent = \"CLEAR\";\n}\n\n// --- Priorité ---\nif (msg.priority) {\n    priority = msg.priority;\n} else if (msg.urgent === true) {\n    priority = \"URGENT\";\n}\n\n// --- Payload ---\npayload = msg.payload || {};\n\n// --- Construction finale ---\nmsg.event = {\n    source,\n    intent,\n    payload,\n    priority\n};\n\n// Nettoyage (optionnel, mais recommandé)\ndelete msg.source;\ndelete msg.intent;\ndelete msg.priority;\ndelete msg.urgent;\n\nreturn msg;",
