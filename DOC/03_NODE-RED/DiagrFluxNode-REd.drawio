        <mxCell id="gvTszDfyXMWfky-8GBaj-103" value="&lt;h3 data-start=&quot;1407&quot; data-end=&quot;1444&quot;&gt;&lt;ul&gt;&lt;li style=&quot;&quot;&gt;&lt;font style=&quot;&quot;&gt;&lt;font style=&quot;&quot;&gt;&lt;p style=&quot;font-size: 11px; font-weight: normal; margin-bottom: 0cm;&quot;&gt;&lt;code class=&quot;western&quot; style=&quot;&quot;&gt;RZ_GestionFlux&lt;/code&gt; :&lt;/p&gt;&lt;ul style=&quot;font-size: 11px; font-weight: normal;&quot;&gt;&lt;li&gt;&lt;p style=&quot;margin-bottom: 0cm&quot;&gt;encode VPIV&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p style=&quot;margin-bottom: 0cm&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;choisit le topic (&lt;/span&gt;&lt;code class=&quot;western&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;PtoA&lt;/code&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;,&lt;br&gt;&lt;code class=&quot;western&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;PtoSE&lt;/code&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;, etc.)&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p style=&quot;margin-bottom: 0cm&quot;&gt;publie MQTT&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p style=&quot;margin-bottom: 0cm&quot;&gt;met à jour certaines variables&lt;br&gt;&#x9;globales techniques&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;ul style=&quot;font-size: 11px; font-weight: normal;&quot;&gt;&lt;li&gt;&lt;p style=&quot;margin-bottom: 0cm&quot;&gt;&lt;/p&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;Il ne bloque jamais une&lt;/strong&gt;&lt;/div&gt;&lt;strong&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;décision validée&lt;/strong&gt;&lt;/div&gt;&lt;/strong&gt;&lt;p&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;ul style=&quot;&quot;&gt;&lt;li style=&quot;font-size: 11px; font-weight: normal;&quot;&gt;&lt;p style=&quot;margin-bottom: 0cm&quot;&gt;&lt;/p&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;Il n’interprète plus&lt;/strong&gt;&lt;/div&gt;&lt;strong&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;les règles métier&lt;/strong&gt;&lt;/div&gt;&lt;/strong&gt;&lt;p&gt;&lt;/p&gt;&lt;/li&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;font-size: 11px; font-weight: 400;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;/ul&gt;&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;font style=&quot;font-weight: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;Entrées de&amp;nbsp;&lt;/font&gt;&lt;code data-start=&quot;1428&quot; data-end=&quot;1444&quot; style=&quot;font-weight: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;&lt;font style=&quot;&quot;&gt;RZ_GestionFlux&lt;/font&gt; :&amp;nbsp;&lt;/code&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237)); font-weight: normal;&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;MQTT IN (Arduino → SP)&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;MQTT IN (SE → SP)&