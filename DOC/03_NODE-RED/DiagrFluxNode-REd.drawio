        <mxCell id="gvTszDfyXMWfky-8GBaj-106" value="&lt;h3 data-start=&quot;1732&quot; data-end=&quot;1777&quot;&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;Entrée unique de Gtion_EtatGlobal&lt;/span&gt;&lt;br style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;🔗 link in : EVT_RAW_IN&lt;/span&gt;&lt;br style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;Format minimal obligatoire des msg entrants :&lt;/span&gt;&lt;br style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;msg = {&lt;/span&gt;&lt;br style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;source: &quot;UI&quot; | &quot;VPIV&quot; | &quot;SE&quot; | &quot;SYSTEM&quot; | &quot;JOYSTICK&quot;,&lt;/span&gt;&lt;br style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;eventType: &quot;VAR_CHANGE&quot; | &quot;CMD&quot; | &quot;INFO&quot; | &quot;ERROR&quot;,&lt;/span&gt;&lt;br style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;payload: {&lt;/span&gt;&lt;br style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;var: &quot;CfgS&quot;,&lt;/span&gt;&lt;br style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;prop: &quot;modeRZ&quot;,&lt;/span&gt;&lt;br style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;inst: &quot;*&quot;,&lt;/span&gt;&lt;br style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;val: &quot;VEILLE&quot;&lt;/sp