        <mxCell id="gvTszDfyXMWfky-8GBaj-143" value="&lt;ul&gt;&lt;li&gt;&lt;p class=&quot;ds-markdown-paragraph&quot;&gt;&lt;strong&gt;Pages UI&lt;/strong&gt; (à gauche) qui redirigent vers un &lt;strong&gt;Dispatch UI&lt;/strong&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p class=&quot;ds-markdown-paragraph&quot;&gt;Le &lt;strong&gt;Dispatch&lt;/strong&gt; distribue les actions vers différents modules de gestion&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p class=&quot;ds-markdown-paragraph&quot;&gt;Le &lt;strong&gt;module de pilotage&lt;/strong&gt; (GPilot) interagit avec le &lt;strong&gt;noyau&lt;/strong&gt; (RZ)&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p class=&quot;ds-markdown-paragraph&quot;&gt;Tous les modules de gestion convergent vers &lt;strong&gt;l&#39;état global&lt;/strong&gt; (GEtat)&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p class=&quot;ds-markdown-paragraph&quot;&gt;L&#39;état global alimente le noyau qui gère les &lt;strong&gt;variables globales&lt;/strong&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p class=&quot;ds-markdown-paragraph&quot;&gt;Les variables globales influencent à leur tour l&#39;état global&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Cela ressemble à une architecture de type MVC/MVVM avec un dispatcher central et un gestionnaire d&#39;état global.&lt;/span&gt;te" style="shape=note;size=20;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="690" y="1280" width="410" height="240" as="geometry" />
        </mxCell>
